<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    intersection.rou.xml
    定義車輛類型與車流
    
    設計說明：
    - 南北向（主幹道）：車流量大，模擬繁忙主幹道
    - 東西向（次要道）：車流量小，模擬一般道路
    - 使用泊松分佈（probability）模擬隨機車流
-->
<routes>
    <!-- 車輛類型定義 -->
    <vType id="car" 
           accel="2.6"        
           decel="4.5"        
           sigma="0.5"        
           length="5"         
           minGap="2.5"       
           maxSpeed="13.89"   
           guiShape="passenger"/>

    <!-- ==================== 行駛路線定義 ==================== -->
    <!-- 南北向（主幹道）：由北往南 -->
    <route id="route_NS" edges="north_in south_out"/>
    <!-- 南北向（主幹道）：由南往北 -->
    <route id="route_SN" edges="south_in north_out"/>
    <!-- 東西向（次要道）：由東往西 -->
    <route id="route_EW" edges="east_in west_out"/>
    <!-- 東西向（次要道）：由西往東 -->
    <route id="route_WE" edges="west_in east_out"/>

    <!-- ==================== 車流設定 ==================== -->
    <!--
        probability：每秒產生車輛的機率
        - 0.3 = 每秒有 30% 機率產生一台車（較繁忙）
        - 0.1 = 每秒有 10% 機率產生一台車（較稀疏）
        
        主幹道（NS/SN）車流量大 → probability 0.3
        次要道（EW/WE）車流量小 → probability 0.1
    -->
    
    <!-- 主幹道車流（南北向，車多） -->
    <flow id="flow_NS" 
          route="route_NS" 
          begin="0" end="3600" 
          probability="0.3" 
          type="car"/>
    
    <flow id="flow_SN" 
          route="route_SN" 
          begin="0" end="3600" 
          probability="0.3" 
          type="car"/>
    
    <!-- 次要道車流（東西向，車少） -->
    <flow id="flow_EW" 
          route="route_EW" 
          begin="0" end="3600" 
          probability="0.1" 
          type="car"/>
    
    <flow id="flow_WE" 
          route="route_WE" 
          begin="0" end="3600" 
          probability="0.1" 
          type="car"/>
</routes>
